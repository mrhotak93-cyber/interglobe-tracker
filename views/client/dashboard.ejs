<%- include('../partials/header', { title, user }) %>

<section class="hero">
  <div>
    <h1>Suivi client</h1>
    <p class="muted">Consultez vos tournées en cours et vos tournées archivées.</p>
  </div>
</section>

<section class="grid cols-3">
  <article class="card stat-card">
    <div class="stat-label">Tournées actives</div>
    <div class="stat-value"><%= (tours || []).length %></div>
  </article>

  <article class="card stat-card">
    <div class="stat-label">Tournées archivées</div>
    <div class="stat-value"><%= (archivedTours || []).length %></div>
  </article>

  <article class="card stat-card">
    <div class="stat-label">Total</div>
    <div class="stat-value"><%= ((tours || []).length + (archivedTours || []).length) %></div>
  </article>
</section>

<section class="card top-gap">
  <div class="inline-actions">
    <a class="btn primary" href="#tours-actives">Tournées actives</a>
    <a class="btn" href="#tours-archives">Archives</a>
  </div>
</section>

<section class="card top-gap" id="tours-actives">
  <div class="section-header">
    <h2>Tournées actives</h2>
    <span class="badge neutral"><%= (tours || []).length %> résultat(s)</span>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Référence</th>
          <th>Date</th>
          <th>Chauffeur</th>
          <th>Statut</th>
          <th>Km</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!(tours || []).length) { %>
          <tr>
            <td colspan="6" class="muted">Aucune tournée active.</td>
          </tr>
        <% } %>

        <% (tours || []).forEach((tour) => { %>
          <tr>
            <td><strong><%= tour.reference %></strong></td>
            <td><%= tour.date %></td>
            <td><%= tour.driver_name || '-' %></td>
            <td><span class="badge <%= tour.status %>"><%= tour.status %></span></td>
            <td><%= tour.km_total || 0 %> km</td>
            <td>
              <a class="btn small" href="/client/tours/<%= tour.id %>">Ouvrir</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="card top-gap" id="tours-archives">
  <div class="section-header">
    <h2>Archives</h2>
    <span class="badge neutral"><%= (archivedTours || []).length %> résultat(s)</span>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Référence</th>
          <th>Date</th>
          <th>Chauffeur</th>
          <th>Statut</th>
          <th>Km</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!(archivedTours || []).length) { %>
          <tr>
            <td colspan="6" class="muted">Aucune tournée archivée.</td>
          </tr>
        <% } %>

        <% (archivedTours || []).forEach((tour) => { %>
          <tr>
            <td><strong><%= tour.reference %></strong></td>
            <td><%= tour.date %></td>
            <td><%= tour.driver_name || '-' %></td>
            <td>
              <span class="badge <%= tour.status %>"><%= tour.status %></span>
            </td>
            <td><%= tour.km_total || 0 %> km</td>
            <td>
              <a class="btn small" href="/client/tours/<%= tour.id %>">Ouvrir</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
