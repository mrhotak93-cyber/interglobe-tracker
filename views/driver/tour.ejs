<%- include('../partials/header', { title, user }) %>

<section class="hero">
  <div>
    <h1><%= tour.reference %></h1>
    <p class="muted">
      Client : <strong><%= tour.client_name || '-' %></strong> · Date : <strong><%= tour.date %></strong>
    </p>
  </div>
  <div class="actions">
    <form action="/driver/tours/<%= tour.id %>/start" method="POST" class="inline-form">
      <button class="btn primary" type="submit">Commencer la tournée</button>
    </form>
    <form action="/driver/tours/<%= tour.id %>/complete" method="POST" class="inline-form">
      <button class="btn" type="submit">Terminer la tournée</button>
    </form>
  </div>
</section>

<section class="grid cols-4">
  <article class="card stat-card">
    <div class="stat-label">Statut</div>
    <div class="stat-value badge <%= tour.status %>"><%= tour.status %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Début</div>
    <div class="stat-value small-value"><%= formatDateTime(tour.started_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Fin</div>
    <div class="stat-value small-value"><%= formatDateTime(tour.completed_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Km estimés</div>
    <div class="stat-value"><span id="kmValue"><%= tour.km_total || 0 %></span> km</div>
  </article>
</section>

<section class="card top-gap">
  <h2>Tracking GPS</h2>
  <p class="muted">
    Tant que cette page reste ouverte, le navigateur envoie la position au serveur.
    Donne l’autorisation de localisation pour avoir un suivi client en direct.
  </p>
  <div id="gpsStatus" class="gps-status">Initialisation GPS…</div>
</section>

<section class="stack top-gap">
  <% tour.stops.forEach((stop) => { %>
    <article class="stop-card">
      <div class="section-header">
        <div>
          <div class="stop-seq">#<%= stop.sequence_no %> · <%= stop.stop_type === 'loading' ? 'Chargement' : 'Déchargement' %></div>
          <h3><%= stop.name %></h3>
          <div class="muted"><%= stop.address %></div>
        </div>
        <span class="badge <%= stop.status %>"><%= stop.status %></span>
      </div>

      <% if (stop.instructions) { %>
        <p><strong>Instructions :</strong> <%= stop.instructions %></p>
      <% } %>

      <div class="grid cols-3 compact">
        <div><strong>Arrivé :</strong> <%= formatDateTime(stop.arrived_at) || '-' %></div>
        <div><strong>Départ :</strong> <%= formatDateTime(stop.departed_at) || '-' %></div>
        <div><strong>Contact :</strong> <%= stop.contact_name || '-' %> <%= stop.contact_phone ? `(${stop.contact_phone})` : '' %></div>
      </div>

      <div class="inline-actions top-gap">
        <a
          class="btn primary"
          target="_blank"
          href="https://waze.com/ul?q=<%= encodeURIComponent(stop.address) %>&navigate=yes"
        >Ouvrir dans Waze</a>

        <form action="/driver/stops/<%= stop.id %>/arrive" method="POST" class="inline-form">
          <button class="btn" type="submit">Arrivé</button>
        </form>

        <form action="/driver/stops/<%= stop.id %>/depart" method="POST" class="inline-form">
          <button class="btn" type="submit">Départ</button>
        </form>
      </div>

      <form action="/driver/stops/<%= stop.id %>/proofs" method="POST" enctype="multipart/form-data" class="upload-box top-gap">
        <label class="full">
          <span>Ajouter des photos de preuve</span>
          <input type="file" name="photos" multiple accept="image/*" />
        </label>
        <label class="full">
          <span>Note</span>
          <input name="note" placeholder="Optionnel" />
        </label>
        <button class="btn small" type="submit">Envoyer les preuves</button>
      </form>

      <% if (stop.proofs.length) { %>
        <div class="proof-grid top-gap">
          <% stop.proofs.forEach((proof) => { %>
            <a href="<%= proof.image_path %>" target="_blank" class="proof-item">
              <img src="<%= proof.image_path %>" alt="preuve" />
            </a>
          <% }) %>
        </div>
      <% } %>
    </article>
  <% }) %>
</section>

<script>
  (function () {
    const tourId = <%- JSON.stringify(tour.id) %>;
    const statusBox = document.getElementById('gpsStatus');
    const kmValue = document.getElementById('kmValue');

    function updateStatus(text) {
      statusBox.textContent = text;
    }

    async function pushLocation(position) {
      const body = {
        latitude: position.coords.latitude,
        longitude: position.coords.longitude,
        accuracy: position.coords.accuracy
      };

      try {
        const res = await fetch(`/driver/tours/${tourId}/location`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.ok) {
          kmValue.textContent = data.km;
          updateStatus(`Position envoyée à ${new Date().toLocaleTimeString('fr-BE')}`);
        } else {
          updateStatus('Erreur envoi GPS');
        }
      } catch (error) {
        updateStatus('Erreur réseau GPS');
      }
    }

    if (!('geolocation' in navigator)) {
      updateStatus('La géolocalisation n’est pas disponible sur ce navigateur.');
      return;
    }

    navigator.geolocation.watchPosition(
      pushLocation,
      function (error) {
        updateStatus(`Erreur GPS : ${error.message}`);
      },
      {
        enableHighAccuracy: true,
        timeout: 15000,
        maximumAge: 10000
      }
    );
  })();
</script>

<%- include('../partials/footer') %>
