<%- include('../partials/header', { title, user }) %>

<section class="hero">
  <div>
    <h1><%= tour.reference %></h1>
    <p class="muted">
      Date : <strong><%= tour.date %></strong> · Client : <strong><%= tour.client_name || '-' %></strong>
    </p>
  </div>

  <div class="actions">
    <% if (tour.status === 'assigned') { %>
      <form action="/driver/tours/<%= tour.id %>/start" method="POST" class="inline-form">
        <button class="btn primary" type="submit">Démarrer la tournée</button>
      </form>
    <% } %>

    <% if (tour.status !== 'completed') { %>
      <form
        action="/driver/tours/<%= tour.id %>/complete"
        method="POST"
        class="inline-form"
        onsubmit="return confirm('Terminer cette tournée ?');"
      >
        <button class="btn" type="submit">Terminer la tournée</button>
      </form>
    <% } %>
  </div>
</section>

<section class="grid cols-4">
  <article class="card stat-card">
    <div class="stat-label">Statut</div>
    <div class="stat-value badge <%= tour.status %>" id="tourStatus"><%= tour.status %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Début</div>
    <div class="stat-value small-value" id="tourStart"><%= formatDateTime(tour.started_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Fin</div>
    <div class="stat-value small-value" id="tourEnd"><%= formatDateTime(tour.completed_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Km parcourus</div>
    <div class="stat-value"><span id="tourKm"><%= tour.km_total || 0 %></span> km</div>
  </article>
</section>

<section class="stack top-gap">
  <% tour.stops.forEach((stop) => { %>
    <article class="stop-card" data-stop-id="<%= stop.id %>">
      <div class="section-header">
        <div>
          <div class="stop-seq">
            #<%= stop.sequence_no %> · <%= stop.stop_type === 'loading' ? 'Chargement' : 'Déchargement' %>
          </div>
          <h3><%= stop.name %></h3>
          <div class="muted"><%= stop.address %></div>
        </div>
        <span class="badge <%= stop.status %>" data-stop-status><%= stop.status %></span>
      </div>

      <div class="grid cols-2 compact">
        <div><strong>Heure arrivée :</strong> <span data-stop-arrived><%= formatDateTime(stop.arrived_at) || '-' %></span></div>
        <div><strong>Heure départ :</strong> <span data-stop-departed><%= formatDateTime(stop.departed_at) || '-' %></span></div>
      </div>

      <div class="inline-actions top-gap">
        <a
          class="btn small"
          target="_blank"
          href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(stop.address || '') %>"
        >
          Ouvrir dans Google Maps
        </a>

        <% if (stop.contact_phone) { %>
          <a class="btn small" href="tel:<%= stop.contact_phone %>">Appeler le client</a>
        <% } %>

        <% if (stop.status === 'pending' && tour.status !== 'completed') { %>
          <form action="/driver/stops/<%= stop.id %>/arrive" method="POST" class="inline-form">
            <button class="btn small primary" type="submit">Arrivée</button>
          </form>
        <% } %>

        <% if (stop.status === 'arrived' && tour.status !== 'completed') { %>
          <form action="/driver/stops/<%= stop.id %>/depart" method="POST" class="inline-form">
            <button class="btn small" type="submit">Départ</button>
          </form>
        <% } %>
      </div>

      <% if (tour.status !== 'completed') { %>
        <section class="card top-gap">
          <h4>Ajouter une preuve</h4>
          <form
            action="/driver/stops/<%= stop.id %>/proofs"
            method="POST"
            enctype="multipart/form-data"
            class="grid cols-2"
          >
            <label class="full">
              <span>Photos</span>
              <input type="file" name="photos" accept="image/*" multiple />
            </label>

            <label class="full">
              <span>Note</span>
              <input type="text" name="note" placeholder="Commentaire éventuel" />
            </label>

            <div class="form-actions">
              <button class="btn small primary" type="submit">Envoyer la preuve</button>
            </div>
          </form>
        </section>
      <% } %>

      <% if (stop.proofs.length) { %>
        <div class="proof-grid top-gap">
          <% stop.proofs.forEach((proof) => { %>
            <a href="<%= proof.image_path %>" target="_blank" class="proof-item">
              <img src="<%= proof.image_path %>" alt="preuve" />
            </a>
          <% }) %>
        </div>
      <% } %>
    </article>
  <% }) %>
</section>

<script>
  (function () {
    const tourId = <%- JSON.stringify(tour.id) %>;

    function toLocal(iso) {
      if (!iso) return '-';
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return iso;
      return d.toLocaleString('fr-BE');
    }

    async function refreshStatus() {
      try {
        const res = await fetch(`/api/tours/${tourId}/status`);
        const data = await res.json();
        if (!data.ok) return;

        document.getElementById('tourStatus').textContent = data.tour.status;
        document.getElementById('tourStatus').className = `stat-value badge ${data.tour.status}`;
        document.getElementById('tourStart').textContent = toLocal(data.tour.started_at);
        document.getElementById('tourEnd').textContent = toLocal(data.tour.completed_at);
        document.getElementById('tourKm').textContent = data.tour.km_total;

        data.tour.stops.forEach((stop) => {
          const root = document.querySelector(`[data-stop-id="${stop.id}"]`);
          if (!root) return;
          const statusEl = root.querySelector('[data-stop-status]');
          const arrivedEl = root.querySelector('[data-stop-arrived]');
          const departedEl = root.querySelector('[data-stop-departed]');
          statusEl.textContent = stop.status;
          statusEl.className = `badge ${stop.status}`;
          arrivedEl.textContent = toLocal(stop.arrived_at);
          departedEl.textContent = toLocal(stop.departed_at);
        });
      } catch (error) {
        console.error(error);
      }
    }

    setInterval(refreshStatus, 10000);
  })();
</script>

<%- include('../partials/footer') %>