<%- include('../partials/header', { title, user }) %>

<%
  const stops = tour.stops || [];
  let currentIndex = stops.findIndex((s) => s.status !== 'done');
  if (currentIndex === -1) currentIndex = 0;

  function encodeAddress(stop) {
    const text = stop && (stop.address || [
      [stop.street, stop.street_no || stop.street_number].filter(Boolean).join(' '),
      [stop.postal_code, stop.city].filter(Boolean).join(' ')
    ].filter(Boolean).join(', '));
    return encodeURIComponent(text || '');
  }

  function hasCoords(stop) {
    return !!(stop && stop.latitude && stop.longitude);
  }

  function wazeLink(stop) {
    if (!stop) return '#';
    if (hasCoords(stop)) {
      return `https://www.waze.com/ul?ll=${stop.latitude},${stop.longitude}&navigate=yes`;
    }
    const q = encodeAddress(stop);
    return q ? `https://www.waze.com/ul?q=${q}&navigate=yes` : '#';
  }

  function googleMapsLink(stop) {
    if (!stop) return '#';
    if (hasCoords(stop)) {
      return `https://www.google.com/maps?q=${stop.latitude},${stop.longitude}`;
    }
    const q = encodeAddress(stop);
    return q ? `https://www.google.com/maps/search/?api=1&query=${q}` : '#';
  }
%>

<div class="mobile-driver-shell ultra-driver-shell">
  <section class="mobile-driver-topcard">
    <div class="mobile-driver-head">
      <div>
        <h1 class="mobile-driver-title"><%= tour.reference %></h1>
        <p class="mobile-driver-subtitle">
          Client : <strong><%= tour.client_name || '-' %></strong>
        </p>
      </div>
      <div>
        <span class="badge <%= tour.status %>"><%= tour.status %></span>
      </div>
    </div>

    <div class="mobile-driver-kpis">
      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Début</div>
        <div class="mobile-driver-kpi-value small-value">
          <%= tour.started_at ? formatDateTime(tour.started_at) : '-' %>
        </div>
      </div>

      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Km</div>
        <div class="mobile-driver-kpi-value"><%= tour.km_total || 0 %> km</div>
      </div>
    </div>

    <div class="mobile-driver-actions">
      <form method="POST" action="/driver/tours/<%= tour.id %>/start">
        <button type="submit" class="btn btn-success">Commencer</button>
      </form>

      <form method="POST" action="/driver/tours/<%= tour.id %>/complete" onsubmit="return confirm('Terminer cette tournée ?');">
        <button type="submit" class="btn btn-danger">Terminer</button>
      </form>
    </div>
  </section>

  <section class="mobile-driver-status">
    <h2 class="mobile-driver-stop-title">Tracking GPS</h2>
    <div id="gps-status" class="mobile-driver-gps-box">Initialisation GPS…</div>
  </section>

  <% if (stops.length) { %>
    <section class="mobile-driver-stop mobile-driver-current ultra-current-stop">
      <div class="mobile-driver-stop-badge">Arrêt actif</div>

      <div class="ultra-progress">
        Arrêt <span id="current-stop-number"><%= currentIndex + 1 %></span> / <%= stops.length %>
      </div>

      <% stops.forEach((stop, index) => { %>
        <div
          class="ultra-stop-slide <%= index === currentIndex ? 'is-active' : '' %>"
          data-stop-index="<%= index %>"
        >
          <h2 class="mobile-driver-stop-title">
            #<%= index + 1 %> · <%= stop.stop_type %>
          </h2>

          <p class="mobile-driver-main-name"><strong><%= stop.name %></strong></p>
          <p class="mobile-driver-line"><%= stop.address || '-' %></p>

          <% if (stop.instructions) { %>
            <p class="mobile-driver-line">
              <strong>Instructions :</strong> <%= stop.instructions %>
            </p>
          <% } %>

          <p class="mobile-driver-line">
            <strong>Statut :</strong>
            <span class="badge <%= stop.status %>"><%= stop.status %></span>
          </p>

          <p class="mobile-driver-line">
            <strong>Arrivé :</strong>
            <%= stop.arrived_at ? formatDateTime(stop.arrived_at) : '-' %>
          </p>

          <p class="mobile-driver-line">
            <strong>Départ :</strong>
            <%= stop.departed_at ? formatDateTime(stop.departed_at) : '-' %>
          </p>

          <p class="mobile-driver-line">
            <strong>Contact :</strong>
            <%= stop.contact_name || '-' %>
            <%= stop.contact_phone ? ' - ' + stop.contact_phone : '' %>
          </p>

          <div class="mobile-driver-actions ultra-actions">
            <% if (wazeLink(stop) !== '#') { %>
              <a
                class="btn btn-waze"
                target="_blank"
                rel="noopener noreferrer"
                href="<%= wazeLink(stop) %>"
              >
                Waze
              </a>
            <% } else { %>
              <button type="button" class="btn btn-muted" disabled>Waze</button>
            <% } %>

            <% if (googleMapsLink(stop) !== '#') { %>
              <a
                class="btn btn-maps"
                target="_blank"
                rel="noopener noreferrer"
                href="<%= googleMapsLink(stop) %>"
              >
                Maps
              </a>
            <% } else { %>
              <button type="button" class="btn btn-muted" disabled>Maps</button>
            <% } %>

            <% if (stop.contact_phone) { %>
              <a class="btn btn-call" href="tel:<%= stop.contact_phone %>">Appeler</a>
            <% } else { %>
              <button type="button" class="btn btn-muted" disabled>Appeler</button>
            <% } %>

            <form method="POST" action="/driver/stops/<%= stop.id %>/arrive">
              <button type="submit" class="btn btn-success">Arrivé</button>
            </form>

            <form method="POST" action="/driver/stops/<%= stop.id %>/depart">
              <button type="submit" class="btn">Départ</button>
            </form>
          </div>

          <div class="mobile-driver-proof">
            <h3>Preuve de livraison</h3>

            <form method="POST" action="/driver/stops/<%= stop.id %>/proofs" enctype="multipart/form-data">
              <input type="file" name="photos" multiple accept="image/*" capture="environment" />
              <textarea name="note" placeholder="Note optionnelle"></textarea>
              <button type="submit" class="btn primary">Envoyer les preuves</button>
            </form>
          </div>
        </div>
      <% }) %>

      <div class="ultra-nav-buttons">
        <button type="button" class="btn btn-muted" id="prev-stop-btn">Arrêt précédent</button>
        <button type="button" class="btn primary" id="next-stop-btn">Arrêt suivant</button>
      </div>
    </section>

    <section class="mobile-driver-stop-list">
      <div class="section-header">
        <h2>Vue rapide tournée</h2>
      </div>

      <% stops.forEach((stop, index) => { %>
        <div class="ultra-stop-summary <%= index === currentIndex ? 'active' : '' %>">
          <div>
            <strong>#<%= index + 1 %> - <%= stop.name %></strong>
            <div class="small-muted"><%= stop.address || '-' %></div>
          </div>
          <div>
            <span class="badge <%= stop.status %>"><%= stop.status %></span>
          </div>
        </div>
      <% }) %>
    </section>
  <% } else { %>
    <section class="mobile-driver-stop">
      <h2 class="mobile-driver-stop-title">Aucun arrêt</h2>
      <p class="mobile-driver-line">Cette tournée ne contient encore aucun arrêt.</p>
    </section>
  <% } %>

  <div class="mobile-driver-nav">
    <div class="mobile-driver-nav-grid">
      <form method="POST" action="/driver/tours/<%= tour.id %>/start">
        <button type="submit" class="btn btn-success">Commencer</button>
      </form>

      <form method="POST" action="/driver/tours/<%= tour.id %>/complete" onsubmit="return confirm('Terminer cette tournée ?');">
        <button type="submit" class="btn btn-danger">Terminer</button>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    const gpsStatus = document.getElementById('gps-status');
    const tourId = "<%= tour.id %>";
    let watchId = null;

    function updateStatus(text) {
      if (gpsStatus) gpsStatus.textContent = text;
    }

    async function sendPosition(position) {
      try {
        const res = await fetch(`/driver/tours/${tourId}/location`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
            accuracy: position.coords.accuracy
          })
        });

        const data = await res.json();
        if (data.ok) {
          updateStatus(`GPS actif · ${data.km} km`);
        } else {
          updateStatus('Erreur GPS');
        }
      } catch (err) {
        updateStatus('Envoi GPS impossible');
      }
    }

    function startGps() {
      if (!navigator.geolocation) {
        updateStatus('Géolocalisation non supportée');
        return;
      }

      watchId = navigator.geolocation.watchPosition(
        sendPosition,
        function () {
          updateStatus('Autorisation GPS refusée ou indisponible');
        },
        {
          enableHighAccuracy: true,
          maximumAge: 5000,
          timeout: 10000
        }
      );
    }

    startGps();

    window.addEventListener('beforeunload', function () {
      if (watchId !== null && navigator.geolocation) {
        navigator.geolocation.clearWatch(watchId);
      }
    });
  })();

  (function () {
    const slides = Array.from(document.querySelectorAll('.ultra-stop-slide'));
    const prevBtn = document.getElementById('prev-stop-btn');
    const nextBtn = document.getElementById('next-stop-btn');
    const currentStopNumber = document.getElementById('current-stop-number');

    if (!slides.length || !prevBtn || !nextBtn) return;

    let currentIndex = slides.findIndex((el) => el.classList.contains('is-active'));
    if (currentIndex < 0) currentIndex = 0;

    function renderSlide() {
      slides.forEach((slide, index) => {
        slide.classList.toggle('is-active', index === currentIndex);
      });

      if (currentStopNumber) {
        currentStopNumber.textContent = currentIndex + 1;
      }

      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex === slides.length - 1;
    }

    prevBtn.addEventListener('click', function () {
      if (currentIndex > 0) {
        currentIndex -= 1;
        renderSlide();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    nextBtn.addEventListener('click', function () {
      if (currentIndex < slides.length - 1) {
        currentIndex += 1;
        renderSlide();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    renderSlide();
  })();
</script>

<%- include('../partials/footer') %>