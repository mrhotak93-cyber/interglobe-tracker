<%- include('../partials/header', { title, user }) %>

<div class="mobile-driver-shell">
  <section class="mobile-driver-topcard">
    <h1 class="mobile-driver-title"><%= tour.reference %></h1>
    <p class="mobile-driver-subtitle">
      Interface terrain chauffeur - simple, rapide et mobile.
    </p>

    <div class="mobile-driver-kpis">
      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Statut</div>
        <div class="mobile-driver-kpi-value"><%= tour.status %></div>
      </div>

      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Km estimés</div>
        <div class="mobile-driver-kpi-value"><%= tour.km_total || 0 %> km</div>
      </div>

      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Début</div>
        <div class="mobile-driver-kpi-value"><%= tour.started_at ? formatDateTime(tour.started_at) : '-' %></div>
      </div>

      <div class="mobile-driver-kpi">
        <div class="mobile-driver-kpi-label">Fin</div>
        <div class="mobile-driver-kpi-value"><%= tour.completed_at ? formatDateTime(tour.completed_at) : '-' %></div>
      </div>
    </div>

    <div class="mobile-driver-actions">
      <form method="POST" action="/driver/tours/<%= tour.id %>/start">
        <button type="submit" class="btn btn-success">Commencer la tournée</button>
      </form>

      <form method="POST" action="/driver/tours/<%= tour.id %>/complete">
        <button type="submit" class="btn btn-danger">Terminer la tournée</button>
      </form>
    </div>
  </section>

  <section class="mobile-driver-status">
    <h2 class="mobile-driver-stop-title">Tracking GPS</h2>
    <p class="mobile-driver-line">
      Tant que cette page reste ouverte, le navigateur envoie la position au serveur.
      Donne l’autorisation de localisation pour avoir un suivi client en direct.
    </p>
    <div id="gps-status" class="mobile-driver-line">Initialisation GPS…</div>
  </section>

  <% tour.stops.forEach((stop, index) => { %>
    <section class="mobile-driver-stop">
      <h2 class="mobile-driver-stop-title">#<%= index + 1 %> · <%= stop.stop_type %></h2>

      <p class="mobile-driver-line"><strong><%= stop.name %></strong></p>
      <p class="mobile-driver-line"><%= stop.address || '-' %></p>

      <% if (stop.instructions) { %>
        <p class="mobile-driver-line"><strong>Instructions :</strong> <%= stop.instructions %></p>
      <% } %>

      <p class="mobile-driver-line"><strong>Arrivé :</strong> <%= stop.arrived_at ? formatDateTime(stop.arrived_at) : '-' %></p>
      <p class="mobile-driver-line"><strong>Départ :</strong> <%= stop.departed_at ? formatDateTime(stop.departed_at) : '-' %></p>
      <p class="mobile-driver-line"><strong>Contact :</strong> <%= stop.contact_name || '-' %> <%= stop.contact_phone ? ' - ' + stop.contact_phone : '' %></p>

      <div class="mobile-driver-actions">
        <% if (stop.latitude && stop.longitude) { %>
          <a
            class="btn btn-waze"
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.waze.com/ul?ll=<%= stop.latitude %>,<%= stop.longitude %>&navigate=yes"
          >
            Ouvrir dans Waze
          </a>
        <% } else { %>
          <button type="button" class="btn btn-muted" disabled>Waze indisponible</button>
        <% } %>

        <form method="POST" action="/driver/stops/<%= stop.id %>/arrive">
          <button type="submit" class="btn btn-success">Arrivé</button>
        </form>

        <form method="POST" action="/driver/stops/<%= stop.id %>/depart">
          <button type="submit" class="btn">Départ</button>
        </form>
      </div>

      <div class="mobile-driver-proof">
        <h3>Ajouter des photos de preuve</h3>

        <form method="POST" action="/driver/stops/<%= stop.id %>/proofs" enctype="multipart/form-data">
          <input type="file" name="photos" multiple accept="image/*" />
          <textarea name="note" placeholder="Note optionnelle"></textarea>
          <button type="submit" class="btn primary">Envoyer les preuves</button>
        </form>
      </div>
    </section>
  <% }) %>

  <div class="mobile-driver-nav">
    <div class="mobile-driver-nav-grid">
      <form method="POST" action="/driver/tours/<%= tour.id %>/start">
        <button type="submit" class="btn btn-success">Commencer</button>
      </form>

      <form method="POST" action="/driver/tours/<%= tour.id %>/complete">
        <button type="submit" class="btn btn-danger">Terminer</button>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    const gpsStatus = document.getElementById('gps-status');
    const tourId = "<%= tour.id %>";
    let watchId = null;

    function updateStatus(text) {
      if (gpsStatus) gpsStatus.textContent = text;
    }

    async function sendPosition(position) {
      try {
        const res = await fetch(`/driver/tours/${tourId}/location`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
            accuracy: position.coords.accuracy
          })
        });

        const data = await res.json();
        if (data.ok) {
          updateStatus(`GPS actif · ${data.km} km`);
        } else {
          updateStatus('Erreur GPS');
        }
      } catch (err) {
        updateStatus('Envoi GPS impossible');
      }
    }

    function startGps() {
      if (!navigator.geolocation) {
        updateStatus('Géolocalisation non supportée');
        return;
      }

      watchId = navigator.geolocation.watchPosition(
        sendPosition,
        function () {
          updateStatus('Autorisation GPS refusée ou indisponible');
        },
        {
          enableHighAccuracy: true,
          maximumAge: 5000,
          timeout: 10000
        }
      );
    }

    startGps();

    window.addEventListener('beforeunload', function () {
      if (watchId !== null && navigator.geolocation) {
        navigator.geolocation.clearWatch(watchId);
      }
    });
  })();
</script>

<%- include('../partials/footer') %>