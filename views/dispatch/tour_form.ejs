<%- include('../partials/header', { title, user }) %>

<section class="card narrow">
  <h1>Modifier la tournée</h1>

  <form action="/dispatch/tours/<%= tour.id %>/edit" method="POST" class="grid cols-2">
    <label>
      <span>Référence</span>
      <input name="reference" value="<%= tour.reference %>" required />
    </label>

    <label>
      <span>Date</span>
      <input type="date" name="date" value="<%= tour.date %>" required />
    </label>

    <label>
      <span>Chauffeur</span>
      <select name="driver_id" id="edit-driver-select">
        <option value="">-- Choisir --</option>
        <% drivers.forEach((driver) => { %>
          <option value="<%= driver.id %>" data-driver-type="<%= driver.driver_type || 'internal' %>" <%= String(tour.driver_id || '') === String(driver.id) ? 'selected' : '' %>><%= driver.full_name %><%= driver.driver_type === 'subcontractor' ? ' · Sous-traitant' : '' %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Client</span>
      <select name="client_id">
        <option value="">-- Choisir --</option>
        <% clients.forEach((client) => { %>
          <option value="<%= client.id %>" <%= String(tour.client_id || '') === String(client.id) ? 'selected' : '' %>><%= client.full_name %></option>
        <% }) %>
      </select>
    </label>

    <label id="edit-subcontractor-price" style="display:none;">
      <span>Prix convenu sous-traitant (€)</span>
      <input type="number" step="0.01" min="0" name="subcontractor_price" value="<%= tour.subcontractor_price || '' %>" />
    </label>

    <label>
      <span>Statut</span>
      <select name="status">
        <option value="draft" <%= tour.status === 'draft' ? 'selected' : '' %>>draft</option>
        <option value="assigned" <%= tour.status === 'assigned' ? 'selected' : '' %>>assigned</option>
        <option value="in_progress" <%= tour.status === 'in_progress' ? 'selected' : '' %>>in_progress</option>
        <option value="completed" <%= tour.status === 'completed' ? 'selected' : '' %>>completed</option>
      </select>
    </label>

    <label class="full">
      <span>Notes</span>
      <textarea name="notes" rows="4"><%= tour.notes || '' %></textarea>
    </label>

    <div class="form-actions">
      <button class="btn primary" type="submit">Enregistrer</button>
      <a class="btn" href="/dispatch/tours/<%= tour.id %>">Retour</a>
    </div>
  </form>
</section>


<script>
  (function () {
    const driverSelect = document.getElementById('edit-driver-select');
    const priceBlock = document.getElementById('edit-subcontractor-price');
    if (!driverSelect || !priceBlock) return;

    function refreshPriceBlock() {
      const option = driverSelect.options[driverSelect.selectedIndex];
      const isSubcontractor = option && option.dataset.driverType === 'subcontractor';
      priceBlock.style.display = isSubcontractor ? '' : 'none';
      const input = priceBlock.querySelector('input');
      if (input) input.required = isSubcontractor;
      if (input && !isSubcontractor) input.value = '';
    }

    driverSelect.addEventListener('change', refreshPriceBlock);
    refreshPriceBlock();
  })();
</script>

<%- include('../partials/footer') %>
