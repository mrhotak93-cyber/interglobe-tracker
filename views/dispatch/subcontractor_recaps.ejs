<%- include('../partials/header', { title, user }) %>

<section class="hero">
  <div>
    <h1>Récapitulatif sous-traitants</h1>
    <p class="muted">Vue dispatch des courses sous-traitants, montants d’attente et montants à payer.</p>
  </div>
  <div class="inline-actions">
    <a class="btn" href="/dispatch/tours">Retour aux tournées</a>
  </div>
</section>

<section class="card">
  <form method="GET" action="/dispatch/subcontractors/recap" class="grid cols-3">
    <label>
      <span>Mois</span>
      <input type="month" name="month" value="<%= selectedMonth %>" required />
    </label>
    <div class="form-actions">
      <button class="btn primary" type="submit">Afficher</button>
      <a class="btn" href="/dispatch/subcontractors/recap/export.csv?month=<%= selectedMonth %>">Exporter CSV</a>
      <a class="btn primary" href="/dispatch/subcontractors/recap/export.pdf?month=<%= selectedMonth %>">Exporter PDF</a>
    </div>
  </form>
</section>

<section class="stats top-gap">
  <article class="stat card">
    <span>Courses du mois</span>
    <strong><%= recap.totals.allCount %></strong>
  </article>
  <article class="stat card">
    <span>Courses terminées</span>
    <strong><%= recap.totals.completedCount %></strong>
  </article>
  <article class="stat card">
    <span>Total attentes</span>
    <strong><%= recap.totals.totalWaitingAmountLabel %></strong>
  </article>
  <article class="stat card">
    <span>Total à payer</span>
    <strong><%= recap.totals.totalAmountLabel %></strong>
  </article>
</section>

<% if (!recap.recaps.length) { %>
  <section class="card top-gap">
    <p class="muted">Aucun sous-traitant créé.</p>
  </section>
<% } %>

<% recap.recaps.forEach((item) => { %>
  <section class="card top-gap">
    <div class="section-header">
      <div>
        <h2><%= item.driver.full_name %></h2>
        <p class="muted">
          <%= item.totals.completedCount %> terminée(s) · <%= item.totals.pendingCount %> en attente ·
          Prix courses : <strong><%= item.totals.totalBaseAmountLabel %></strong> ·
          Attentes : <strong><%= item.totals.totalWaitingAmountLabel %></strong> ·
          Total : <strong><%= item.totals.totalAmountLabel %></strong>
        </p>
      </div>
      <span class="badge neutral"><%= selectedMonth %></span>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Référence</th>
            <th>Client</th>
            <th>Véhicule</th>
            <th>Statut</th>
            <th>Prix course</th>
            <th>Attente</th>
            <th>Total</th>
            <th>Modifier attente</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (!item.tours.length) { %>
            <tr>
              <td colspan="10" class="muted">Aucune course pour ce sous-traitant ce mois-ci.</td>
            </tr>
          <% } %>

          <% item.tours.forEach((tour) => { %>
            <tr>
              <td><%= tour.date %></td>
              <td><strong><%= tour.reference %></strong></td>
              <td><%= tour.client_name || '-' %></td>
              <td><%= tour.vehicle_label || '-' %></td>
              <td><span class="badge <%= tour.status %>"><%= tour.status %></span></td>
              <td><%= tour.subcontractor_price_label %></td>
              <td><strong><%= tour.waiting_amount_label %></strong></td>
              <td><strong><%= tour.subcontractor_total_label %></strong></td>
              <td>
                <form method="POST" action="/dispatch/tours/<%= tour.id %>/waiting-amount" class="inline-form">
                  <input type="hidden" name="month" value="<%= selectedMonth %>" />
                  <input type="number" step="0.01" min="0" name="waiting_amount" value="<%= Number(tour.waiting_amount || 0) %>" style="max-width: 100px;" />
                  <button class="btn small" type="submit">OK</button>
                </form>
              </td>
              <td><a class="btn small" href="/dispatch/tours/<%= tour.id %>">Détail</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
<% }) %>

<%- include('../partials/footer') %>
