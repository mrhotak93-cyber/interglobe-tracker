<%- include('../partials/header', { title, user }) %>

<section class="hero">
  <div>
    <h1><%= tour.reference %></h1>
    <p class="muted">
      Date : <strong><%= tour.date %></strong> · Chauffeur : <strong><%= tour.driver_name || '-' %></strong> · Client : <strong><%= tour.client_name || '-' %></strong>
    </p>
  </div>
  <div class="actions">
    <a class="btn" href="/dispatch/tours/<%= tour.id %>/edit">Modifier tournée</a>
    <a class="btn" href="/dispatch/tours/<%= tour.id %>/export.csv">Exporter arrêts CSV</a>
    <a class="btn" href="/dispatch/recurrences">Créer / gérer les récurrences</a>
  </div>
</section>

<section class="grid cols-4">
  <article class="card stat-card">
    <div class="stat-label">Statut</div>
    <div class="stat-value badge <%= tour.status %>"><%= tour.status %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Avancement</div>
    <div class="stat-value small-value"><%= tour.metrics.doneStops %>/<%= tour.metrics.totalStops %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Preuves</div>
    <div class="stat-value"><%= tour.metrics.proofCount %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Km</div>
    <div class="stat-value"><%= tour.km_total || 0 %></div>
  </article>
</section>

<section class="grid cols-3 top-gap">
  <article class="card stat-card">
    <div class="stat-label">Début</div>
    <div class="stat-value small-value"><%= formatDateTime(tour.started_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">Fin</div>
    <div class="stat-value small-value"><%= formatDateTime(tour.completed_at) || '-' %></div>
  </article>
  <article class="card stat-card">
    <div class="stat-label">GPS</div>
    <div class="stat-value small-value"><%= tour.latestLocation ? 'il y a ' + tour.latestLocation.minutes_since + ' min' : 'jamais reçu' %></div>
  </article>
</section>

<section class="split top-gap">
  <article class="card">
    <h2>Ajouter un arrêt</h2>
    <form action="/dispatch/tours/<%= tour.id %>/stops" method="POST" class="grid cols-2">
      <label>
        <span>Ordre</span>
        <input type="number" name="sequence_no" value="<%= (tour.stops.length || 0) + 1 %>" required />
      </label>
      <label>
        <span>Type</span>
        <select name="stop_type" required>
          <option value="loading">Chargement</option>
          <option value="unloading">Déchargement</option>
        </select>
      </label>
      <label>
        <span>Nom</span>
        <input name="name" required />
      </label>
      <label>
        <span>Rue</span>
        <input name="street" required />
      </label>
      <label>
        <span>N°</span>
        <input name="street_no" />
      </label>
      <label>
        <span>Code postal</span>
        <input name="postal_code" />
      </label>
      <label>
        <span>Commune</span>
        <input name="city" />
      </label>
      <label>
        <span>Contact</span>
        <input name="contact_name" />
      </label>
      <label>
        <span>Téléphone</span>
        <input name="contact_phone" />
      </label>
      <label class="full">
        <span>Instructions</span>
        <textarea name="instructions" rows="3"></textarea>
      </label>
      <div class="form-actions">
        <button class="btn primary" type="submit">Ajouter l’arrêt</button>
      </div>
    </form>
  </article>

  <article class="card">
    <h2>Monitoring terrain</h2>
    <div class="stack">
      <div><strong>Chauffeur :</strong> <%= tour.driver_name || '-' %></div>
      <div><strong>Téléphone :</strong> <%= tour.driver_phone || '-' %></div>
      <div><strong>Dernier GPS :</strong> <%= tour.latestLocation ? formatDateTime(tour.latestLocation.created_at) : 'jamais reçu' %></div>
      <div><strong>Arrêts en retard :</strong> <%= tour.metrics.overdueStops %></div>
      <% if (tour.latestLocation) { %>
        <div class="inline-actions top-gap">
          <a class="btn small" target="_blank" href="<%= tour.latestLocation.maps_link %>">Voir la position</a>
        </div>
      <% } %>
    </div>
  </article>
</section>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<section class="card top-gap">
  <div class="section-header">
    <h2>Trajet du chauffeur</h2>
    <% if (tour.latestLocation) { %>
      <a class="btn small" target="_blank" href="<%= tour.latestLocation.maps_link %>">Voir position actuelle</a>
    <% } %>
  </div>

  <div id="tour-map" style="height: 420px; border-radius: 16px; overflow: hidden;"></div>

  <p class="muted top-gap">
    Affichage de la position actuelle et du tracé complet du trajet.
  </p>
</section>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    const rawPoints = <%- JSON.stringify((tour.routePoints || []).map((p) => ({
      lat: Number(p.latitude),
      lng: Number(p.longitude),
      tracked_at: p.tracked_at
    }))) %>;

    const map = L.map('tour-map');
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    let routeLayer = null;
    let startMarker = null;
    let currentMarker = null;

    function drawRoute(points) {
      if (routeLayer) map.removeLayer(routeLayer);
      if (startMarker) map.removeLayer(startMarker);
      if (currentMarker) map.removeLayer(currentMarker);

      if (!points.length) {
        map.setView([50.8503, 4.3517], 8);
        return;
      }

      const latlngs = points.map((p) => [p.lat, p.lng]);

      if (points.length === 1) {
        currentMarker = L.marker(latlngs[0]).addTo(map).bindPopup('Position actuelle');
        map.setView(latlngs[0], 15);
        return;
      }

      routeLayer = L.polyline(latlngs, {
        color: '#133b72',
        weight: 5
      }).addTo(map);

      startMarker = L.marker(latlngs[0]).addTo(map).bindPopup('Début du trajet');
      currentMarker = L.marker(latlngs[latlngs.length - 1]).addTo(map).bindPopup('Position actuelle');

      map.fitBounds(routeLayer.getBounds(), { padding: [30, 30] });
    }

    drawRoute(rawPoints);

    async function refreshRoute() {
      try {
        const res = await fetch('/api/tours/<%= tour.id %>/status');
        const data = await res.json();
        if (!data.ok) return;

        const points = (data.tour.routePoints || []).map((p) => ({
          lat: Number(p.latitude),
          lng: Number(p.longitude),
          tracked_at: p.tracked_at
        }));

        drawRoute(points);
      } catch (err) {
        console.error('Erreur refresh carte:', err);
      }
    }

    setInterval(refreshRoute, 10000);
  })();
</script>

<section class="card top-gap">
  <div class="section-header">
    <h2>Arrêts de la tournée</h2>
    <% if (tour.latestLocation) { %>
      <a class="btn small" target="_blank" href="<%= tour.latestLocation.maps_link %>">Voir dernière position</a>
    <% } %>
  </div>

  <div class="stack">
    <% if (!tour.stops.length) { %>
      <p class="muted">Aucun arrêt pour le moment.</p>
    <% } %>

    <% tour.stops.forEach((stop) => { %>
      <article class="stop-card">
        <div class="stop-header">
          <div>
            <div class="stop-seq">#<%= stop.sequence_no %> · <%= stop.stop_type === 'loading' ? 'Chargement' : 'Déchargement' %></div>
            <h3><%= stop.name %></h3>
            <div class="muted"><%= stop.address %></div>
          </div>
          <div class="inline-actions">
            <span class="badge <%= stop.is_overdue ? 'warning' : stop.status %>"><%= stop.is_overdue ? 'overdue' : stop.status %></span>
            <a class="btn small" href="/dispatch/stops/<%= stop.id %>/edit">Modifier</a>
            <form action="/dispatch/stops/<%= stop.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Supprimer cet arrêt ?')">
              <button class="btn small danger" type="submit">Supprimer</button>
            </form>
          </div>
        </div>

        <div class="grid cols-3 compact">
          <div><strong>Arrivé :</strong> <%= formatDateTime(stop.arrived_at) || '-' %></div>
          <div><strong>Départ :</strong> <%= formatDateTime(stop.departed_at) || '-' %></div>
          <div><strong>Preuves :</strong> <%= stop.proof_count || 0 %></div>
        </div>

        <% if (stop.instructions) { %>
          <p><strong>Instructions :</strong> <%= stop.instructions %></p>
        <% } %>

        <% if (stop.proofs.length) { %>
          <div class="proof-grid">
            <% stop.proofs.forEach((proof) => { %>
              <a href="<%= proof.image_path %>" target="_blank" class="proof-item">
                <img src="<%= proof.image_path %>" alt="preuve" />
              </a>
            <% }) %>
          </div>
        <% } %>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>